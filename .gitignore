chroma_data/
model_repository/*/1/*.onnx

# ── Training artifacts ────────────────────────────────────────────────────────
# BERT weights are ~420 MB each — generate locally via ./run.sh setup.
# Run ./run.sh retrain to force a full rebuild.
# Tracked:   config.json, tokenizer files, metrics.json  (small metadata)
# Excluded:  model weights, checkpoints, optimizer/scheduler/rng state
training/bert_classifier/checkpoint-*/
training/bert_classifier/*.safetensors
training/bert_classifier/*.bin
training/bert_classifier/*.pt
training/bert_classifier/*.pth

# spaCy NER model outputs — generated by ./run.sh setup; binary/large.
# spacy_ner_model/metrics.json is NOT excluded (small, useful for /metrics page).
training/spacy_ner_model/model-final/
training/spacy_ner_model/train.spacy
training/spacy_ner_model/dev.spacy

# Synthetic training data — BOTH jsonl files are committed so a fresh clone
# skips Ollama-based data generation entirely and goes straight to training.
# To regenerate:  ./run.sh retrain   or   python scripts/setup.py --gen-overwrite
training/data/*.jsonl
!training/data/clause_labels.jsonl
!training/data/ner_annotations.jsonl

